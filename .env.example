# Copy this file to .env.local for local development, or set these as
# environment variables in your hosting panel (e.g. Hostinger hPanel Node.js
# Web App > Environment variables) for production.

# --- Supabase (required for auth + per-user settings) ---
# Project Settings -> API in your Supabase dashboard.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# --- TMDB (optional shared fallback) ---
# Used by /api/movies/search and /api/tmdb/* when a signed-in user hasn't
# saved their own TMDB key in Settings. Provide one of these two.
TMDB_API_KEY=
TMDB_READ_TOKEN=

# --- Debrid providers (optional shared fallback) ---
# Used by /api/debrid/resolve when a request doesn't supply its own token.
# Users can also enter tokens per-request in the app UI.
REAL_DEBRID_TOKEN=
ALLDEBRID_TOKEN=
PREMIUMIZE_TOKEN=
DEBRID_LINK_TOKEN=
OFFCLOUD_TOKEN=
